<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.prodvd" name="ProDVD Player" version="1.1.1" provider-name="azzy9">
    <requires>
        <import addon="script.module.requests"/>
        <import addon="script.module.six"/>
        <import addon="xbmc.webinterface" version="1.0.0"/>
        <import addon="script.module.bottle" version="0.12.8"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.webinterface" type="wsgi" library="server.py" entry="app" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Video</summary>
        <description lang="en">Player for the Samsung SE-208BW ProDVD server</description>
        <disclaimer lang="en"></disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
